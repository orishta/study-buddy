# Backend
DATABASE_URL=sqlite:///./studybuddy.db
ALLOWED_ORIGINS=http://localhost:3000

# AI — Gemini (free tier, 1500 req/day)
# Get your free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# AI — Ollama (local, optional)
# aya-expanse:8b supports Hebrew, Arabic, and 100+ other languages
# Pull it first: ollama pull aya-expanse:8b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=aya-expanse:8b

# Google (Phase 3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Telegram morning brief
# Create a bot via @BotFather in Telegram, then paste the token here
TELEGRAM_BOT_TOKEN=
