# ── Core ──────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./studybuddy.db
ALLOWED_ORIGINS=http://localhost:3000

# ── AI — Local Ollama (default, free, fully private) ─────────────────────────
# Install: https://ollama.com  |  then: ollama pull qwen2.5:7b
# For Hebrew/Arabic support:   ollama pull aya-expanse:8b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── AI — Remote APIs (all optional — leave blank to use Ollama only) ──────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Telegram Bot (optional) ───────────────────────────────────────────────────
# Create a bot via @BotFather, then paste the token here.
# Send any message to the bot to auto-detect your chat ID on the Settings page.
TELEGRAM_BOT_TOKEN=

# ── Gmail OAuth (optional) ────────────────────────────────────────────────────
# Create OAuth credentials at https://console.cloud.google.com (Desktop app type).
# After saving these, send /connect_gmail in Telegram to complete the OAuth flow.
# The refresh_token is stored in the local DB — it does not belong in this file.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
